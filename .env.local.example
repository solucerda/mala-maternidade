# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# (Configurações > API no painel do Supabase)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# URL pública do site (usada em metadados de SEO). Em produção, coloque a URL da Vercel/domínio.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
